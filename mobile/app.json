{
  "expo": {
    "name": "clipX",
    "slug": "clipx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/clipx.png",
    "scheme": "clipx",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 3000,
      "url": "https://u.expo.dev/clipx",
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.clipx",
      "associatedDomains": [
        "applinks:clipx.app",
        "webcredentials:clipx.app"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/clipx.png",
        "backgroundColor": "#000000"
      },
      "package": "com.anonymous.clipx",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "clipx.app",
              "pathPrefix": "/watch"
            },
            {
              "scheme": "https",
              "host": "clipx.app",
              "pathPrefix": "/movies"
            },
            {
              "scheme": "clipx",
              "host": "*"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/clipx.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/clipx.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialCommunityIcons.ttf"
          ]
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow clipX to access your microphone."
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
