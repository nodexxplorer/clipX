{
  "cli": {
    "version": ">= 14.7.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://YOUR_DEV_MACHINE_IP:8000"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://your-staging-api.example.com",
        "EXPO_PUBLIC_REVENUECAT_APPLE": "appl_YOUR_APPLE_API_KEY_HERE",
        "EXPO_PUBLIC_REVENUECAT_GOOGLE": "goog_YOUR_GOOGLE_API_KEY_HERE"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://clipx-api.example.com",
        "EXPO_PUBLIC_REVENUECAT_APPLE": "appl_YOUR_APPLE_API_KEY_HERE",
        "EXPO_PUBLIC_REVENUECAT_GOOGLE": "goog_YOUR_GOOGLE_API_KEY_HERE"
      }
    }
  },
  "submit": {
    "production": {}
  }
}