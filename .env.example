# ─────────────────────────────────────────────────────────────
# ClipX Environment Variables — TEMPLATE
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/clipx
# DATABASE_URL=sqlite+aiosqlite:///./dev.db  # for local dev without postgres

# ── Security (REQUIRED in production) ─────────────────────────
JWT_SECRET=                          # generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
ENVIRONMENT=development              # development | staging | production

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── External APIs ────────────────────────────────────────────
TMDB_API_KEY=                        # themoviedb.org API key
NEXT_PUBLIC_GOOGLE_CLIENT_ID=        # Google OAuth client ID
GOOGLE_CLIENT_SECRET=                # Google OAuth client secret

# ── Paystack (payments) ──────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=                       # app password, not account password

# ── Firebase (push notifications) ────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── App ───────────────────────────────────────────────────────
APP_VERSION=2.0.0
PROJECT_NAME=ClipX
API_V1_STR=/api/v1
